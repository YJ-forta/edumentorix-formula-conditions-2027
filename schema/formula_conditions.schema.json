{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/forta/edumentorix-formula-conditions-2027/schema/formula_conditions.schema.json",
  "title": "Edumentorix 2027 Formula Conditions Export",
  "type": "object",
  "required": [
    "schema_version",
    "summary",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "forta.edumentorix.formula_conditions.v1.1"
    },
    "summary": {
      "type": "object"
    },
    "aliasMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/formula_condition_item"
      }
    }
  },
  "$defs": {
    "formula_condition_item": {
      "type": "object",
      "required": [
        "target_id",
        "identity",
        "components",
        "school_record_rules",
        "csat_rules",
        "external_dependencies",
        "status",
        "formula_text",
        "source_locator"
      ],
      "properties": {
        "target_id": {
          "type": "string"
        },
        "identity": {
          "type": "object"
        },
        "stages": {
          "type": "array"
        },
        "components": {
          "type": "array"
        },
        "school_record_rules": {
          "type": "array"
        },
        "csat_rules": {
          "type": "array"
        },
        "external_dependencies": {
          "type": "array"
        },
        "status": {
          "type": "object",
          "properties": {
            "data_status": {
              "enum": [
                "calculable",
                "waiting_for_final_table",
                "needs_data_fix",
                "needs_review",
                "not_calculable"
              ]
            }
          },
          "required": [
            "data_status"
          ],
          "additionalProperties": true
        },
        "formula_text": {
          "type": "object"
        },
        "source_locator": {
          "type": "object"
        },
        "resolved_review_codes": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  }
}
